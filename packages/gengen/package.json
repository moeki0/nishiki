{
  "name": "@moeki0/gengen",
  "version": "0.0.4",
  "type": "module",
  "description": "Schema DSL for structured LLM Markdown output",
  "keywords": [
    "markdown",
    "llm",
    "schema",
    "gengen"
  ],
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/server.mjs",
      "require": "./dist/server.cjs",
      "types": "./dist/server.d.ts"
    },
    "./react": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/server.cjs",
  "module": "./dist/server.mjs",
  "types": "./dist/server.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.app.json"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-markdown": ">=9",
    "mdast-util-from-markdown": ">=2",
    "mdast-util-to-string": ">=4",
    "mdast-util-to-markdown": ">=2",
    "remark-gfm": ">=4"
  },
  "dependencies": {
    "mdast-util-gfm": "^3.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
